<Window x:Class="VirtualPrinter.Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirtualPrinter" Width="720" Height="540"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource PaperBrush}"
        Foreground="{StaticResource InkBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ====== Left sidebar (方案1宽侧边栏) ====== -->
        <Border Grid.Column="0" Background="{StaticResource WhiteBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo area -->
                <StackPanel Grid.Row="0" Margin="0,24,0,0">
                    <Border Width="40" Height="40" Background="{StaticResource RedBrush}"
                            HorizontalAlignment="Center">
                        <TextBlock Text="V" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VirtualPrinter" FontFamily="{StaticResource DisplayFont}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource MonoBrush}"
                               HorizontalAlignment="Center" Margin="0,6,0,16"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <RadioButton x:Name="NavManage" GroupName="Nav"
                                 Checked="OnNavChanged" Cursor="Hand"
                                 Height="38" Margin="0,0,0,2">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="Bg" Background="Transparent" Padding="16,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="⬇" FontSize="14"
                                                   Foreground="{StaticResource RedBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="安装" FontSize="13"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bg" Property="Background"
                                                Value="{StaticResource RedLightBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background"
                                                Value="{StaticResource PaperBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>

                    <RadioButton x:Name="NavSettings" GroupName="Nav"
                                 Checked="OnNavChanged" Cursor="Hand"
                                 Height="38" Margin="0,0,0,2">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="Bg" Background="Transparent" Padding="16,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="⚙" FontSize="14"
                                                   Foreground="{StaticResource RedBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="设置" FontSize="13"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bg" Property="Background"
                                                Value="{StaticResource RedLightBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background"
                                                Value="{StaticResource PaperBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>

                    <RadioButton x:Name="NavAbout" GroupName="Nav"
                                 Checked="OnNavChanged" Cursor="Hand" Height="38">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border x:Name="Bg" Background="Transparent" Padding="16,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ℹ" FontSize="14"
                                                   Foreground="{StaticResource MonoBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="关于" FontSize="13"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Bg" Property="Background"
                                                Value="{StaticResource RedLightBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background"
                                                Value="{StaticResource PaperBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </StackPanel>

                <!-- Admin status at bottom -->
                <TextBlock Grid.Row="2" x:Name="AdminStatus" FontSize="9"
                           Foreground="{StaticResource MonoBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,12"/>
            </Grid>
        </Border>

        <!-- Vertical divider -->
        <Border Grid.Column="1" Background="{StaticResource BorderBrush}"/>

        <!-- ====== Content ====== -->
        <ScrollViewer Grid.Column="2" BorderThickness="0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel" Margin="28,24,28,28">

                <!-- ====== MANAGE PAGE ====== -->
                <StackPanel x:Name="PageManage">

                    <!-- Test version banner -->
                    <Border Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="1"
                            CornerRadius="6" Padding="14,8" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock x:Name="VersionLabel" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#666666"/>
                            <TextBlock x:Name="BatchLabel" FontSize="11"
                                       Foreground="#999999" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Page header -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="安装" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}"/>
                        <Separator Style="{StaticResource Hairline}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Printer status card (圆角) -->
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="8" Height="8" Margin="0,5,10,0"
                                    Background="{StaticResource GreenBrush}"
                                    CornerRadius="4" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="PrinterStatus" FontSize="14" FontWeight="SemiBold"
                                           Text="● 未检测"/>
                                <TextBlock x:Name="PortInfo" Text="端口: VP_Port (VirtualPrinter 监视器)"
                                           Style="{StaticResource TagLabel}" Margin="0,4,0,1"/>
                                <TextBlock x:Name="DriverInfo" Text="驱动: Canon Generic Plus PS3"
                                           Style="{StaticResource TagLabel}"/>
                                <TextBlock x:Name="ServiceInfo" Text="服务: VirtualPrinterService ● 运行中"
                                           Style="{StaticResource TagLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Environment checks (圆角) -->
                    <TextBlock Text="环境检测" Style="{StaticResource SectionTitle}" Margin="0,20,0,10"/>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="CheckDotNet" Text="⏳ .NET Framework..." Margin="0,2"/>
                                <TextBlock x:Name="CheckVC" Text="⏳ VC++ Redist..." Margin="0,8,0,0"/>
                                <TextBlock x:Name="CheckSpooler" Text="⏳ Print Spooler..." Margin="0,8,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="CheckPS" Text="⏳ Canon PS3 驱动..." Margin="0,2"/>
                                <TextBlock x:Name="CheckGS" Text="⏳ Ghostscript..." Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="安装打印机" Style="{StaticResource BtnPrimary}" Click="OnInstall"/>
                        <Button Content="刷新状态" Style="{StaticResource BtnSecondary}" Margin="8,0,0,0" Click="OnRefresh"/>
                    </StackPanel>

                    <!-- Uninstall (圆角) -->
                    <TextBlock Text="卸载" Style="{StaticResource SectionTitle}" Margin="0,24,0,10"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <CheckBox x:Name="DeletePortCheck" Content="同时删除端口 (VP_Port)" IsChecked="True"/>
                            <CheckBox x:Name="DeleteDriverCheck" Content="同时删除打印机驱动" IsChecked="True" Margin="0,8,0,0"/>
                            <Button Content="卸载打印机" Style="{StaticResource BtnDanger}"
                                    Margin="0,12,0,0" HorizontalAlignment="Left" Click="OnUninstall"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ====== SETTINGS PAGE ====== -->
                <StackPanel x:Name="PageSettings" Visibility="Collapsed">
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="设置" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}"/>
                        <Separator Style="{StaticResource Hairline}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Defaults (圆角) -->
                    <TextBlock Text="全局默认值" Style="{StaticResource SectionTitle}" Margin="0,0,0,10"/>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="默认目录"
                                       Style="{StaticResource TagLabel}"/>
                            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="DefaultSaveDir" IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="浏览…" Style="{StaticResource BtnSecondary}"
                                        Margin="8,0,0,0" Height="30" Padding="12,0" Click="OnBrowseDefaultDir"/>
                            </Grid>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="默认格式"
                                       Style="{StaticResource TagLabel}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DefaultFormatBox"
                                      Margin="0,0,0,6" SelectedIndex="0">
                                <ComboBoxItem Content="PDF"/>
                                <ComboBoxItem Content="PNG"/>
                                <ComboBoxItem Content="JPEG"/>
                                <ComboBoxItem Content="BMP"/>
                                <ComboBoxItem Content="TIFF"/>
                            </ComboBox>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="水印文本"
                                       Style="{StaticResource TagLabel}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="WatermarkDefaultText" Text="Confidential"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ====== ABOUT PAGE ====== -->
                <StackPanel x:Name="PageAbout" Visibility="Collapsed">
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="关于" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}"/>
                        <Separator Style="{StaticResource Hairline}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Padding="28">
                        <StackPanel>
                            <Border Width="48" Height="48"
                                    Background="{StaticResource RedBrush}"
                                    CornerRadius="8" HorizontalAlignment="Left">
                                <TextBlock Text="V" FontFamily="{StaticResource DisplayFont}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock FontFamily="{StaticResource DisplayFont}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,16,0,2">VirtualPrinter</TextBlock>
                            <TextBlock x:Name="AboutVersion" Style="{StaticResource TagLabel}" Margin="0,0,0,12">
                                Windows 虚拟打印机驱动
                            </TextBlock>

                            <Separator Style="{StaticResource Hairline}" Margin="0,0,0,14"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="支持格式"
                                           Style="{StaticResource TagLabel}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"
                                           Foreground="{StaticResource InkBrush}">
                                    PDF / PNG / JPEG / BMP / TIFF</TextBlock>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="支持系统"
                                           Style="{StaticResource TagLabel}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,0,6"
                                           Foreground="{StaticResource InkBrush}">
                                    Windows 7 SP1 / 10 / 11 (x64)</TextBlock>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="技术栈"
                                           Style="{StaticResource TagLabel}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,6"
                                           Foreground="{StaticResource InkBrush}">
                                    C# 服务 + VP_Port 监视器 + Canon PS3 驱动 + Ghostscript</TextBlock>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="开发者"
                                           Style="{StaticResource TagLabel}" Margin="0,0,0,6"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,6"
                                           Foreground="{StaticResource InkBrush}">
                                    YanziWu</TextBlock>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="许可"
                                           Style="{StaticResource TagLabel}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Foreground="{StaticResource InkBrush}">
                                    MIT License</TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>