<Window x:Class="VirtualPrinter.SaveDialog.AdvancedSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="高级设置" Width="400" Height="370"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{StaticResource BodyFont}"
        Background="{StaticResource PaperBrush}"
        Foreground="{StaticResource InkBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="JPEG 质量" Style="{StaticResource SectionTitle}"/>
                <Separator Style="{StaticResource Hairline}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" x:Name="QualitySlider" Minimum="1" Maximum="100"
                            Value="85" TickFrequency="5" TickPlacement="BottomRight"
                            IsSnapToTickEnabled="True"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ElementName=QualitySlider, Path=Value, StringFormat='{}{0}%'}"
                               Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="36"
                               Foreground="{StaticResource MonoBrush}"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="PDF 设置" Style="{StaticResource SectionTitle}"/>
                <Separator Style="{StaticResource Hairline}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="PDF 版本"
                               Style="{StaticResource TagLabel}" Margin="0,0,12,6"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="PdfVersionBox" Margin="0,0,0,6"
                              SelectedIndex="0">
                        <ComboBoxItem Content="1.4"/>
                        <ComboBoxItem Content="1.5"/>
                        <ComboBoxItem Content="1.6"/>
                        <ComboBoxItem Content="1.7"/>
                    </ComboBox>
                    <CheckBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                              x:Name="EmbedFontsCheck" Content="嵌入字体" IsChecked="True"/>
                </Grid>
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Content="关闭" Style="{StaticResource BtnSecondary}"
                Width="90" HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="OnClose"/>
    </Grid>
</Window>