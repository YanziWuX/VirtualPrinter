<Application x:Class="VirtualPrinter.SaveDialog.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 方案3配色 -->
            <Color x:Key="Paper">#F7F3EE</Color>
            <Color x:Key="White">#FFFFFF</Color>
            <Color x:Key="Ink">#2C2C2C</Color>
            <Color x:Key="Mono">#8C8C8C</Color>
            <Color x:Key="Red">#B3413D</Color>
            <Color x:Key="RedLight">#F5E6E5</Color>
            <Color x:Key="Border">#D4D0CB</Color>
            <Color x:Key="Green">#3D6B4F</Color>

            <SolidColorBrush x:Key="PaperBrush" Color="{StaticResource Paper}"/>
            <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
            <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}"/>
            <SolidColorBrush x:Key="MonoBrush" Color="{StaticResource Mono}"/>
            <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>
            <SolidColorBrush x:Key="RedLightBrush" Color="{StaticResource RedLight}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
            <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>

            <FontFamily x:Key="DisplayFont">Yu Gothic UI, Microsoft YaHei, sans-serif</FontFamily>
            <FontFamily x:Key="BodyFont">Segoe UI, Microsoft YaHei, sans-serif</FontFamily>

            <!-- Card: 圆角 -->
            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="8" Opacity="0.04" ShadowDepth="2" Color="#000000"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Red accent button (圆角) -->
            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource RedBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Padding" Value="18,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#992E2B"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.8"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Secondary button (圆角) -->
            <Style x:Key="BtnSecondary" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource PaperBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- TextBox: 圆角 -->
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBox -->
            <Style TargetType="ComboBox">
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Background" Value="{StaticResource WhiteBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            </Style>

            <!-- CheckBox -->
            <Style TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                <Setter Property="Margin" Value="0,3"/>
            </Style>

            <!-- RadioButton -->
            <Style TargetType="RadioButton">
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
                <Setter Property="Margin" Value="0,2"/>
            </Style>

            <!-- Slider -->
            <Style TargetType="Slider">
                <Setter Property="Height" Value="28"/>
            </Style>

            <Style x:Key="Hairline" TargetType="Separator">
                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                <Setter Property="Height" Value="1"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

            <Style x:Key="TagLabel" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource MonoBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>